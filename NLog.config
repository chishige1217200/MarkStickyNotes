<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <targets async="true">
    <!-- メインログファイル -->
    <target name="logfile"
            xsi:type="File"
            fileName="${basedir}/logs/app-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message}${onexception:${newline}${exception:format=tostring}}" />

    <!-- エラーログファイル -->
    <target name="errorfile"
            xsi:type="File"
            fileName="${basedir}/logs/error-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message}${onexception:${newline}${exception:format=tostring}}"
            condition="level >= LogLevel.Error" />

    <!-- デバッグログファイル -->
    <target name="debugfile"
            xsi:type="File"
            fileName="${basedir}/logs/debug-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true} | ${logger} | ${callSite:fileName=True}:${line} | ${message}${onexception:${newline}${exception:format=tostring}}" />
  </targets>

  <rules>
    <!-- すべてのログをlogfileに出力 -->
    <logger name="*" minlevel="Info" writeTo="logfile" />

    <!-- エラー以上をerrorfileに出力 -->
    <logger name="*" minlevel="Error" writeTo="errorfile" />

    <!-- デバッグ用（必要に応じて有効化） -->
    <!-- <logger name="*" minlevel="Debug" writeTo="debugfile" /> -->
  </rules>
</nlog>
